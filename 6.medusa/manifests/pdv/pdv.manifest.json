{
  "panda_manifest_version": "1.0.0",
  "id": "pdv",
  "name": "Panda PDV",
  "version": "1.0.0",
  "description": "Point of sale with digital menu, order management and cart",
  "author": "Panda Factory",
  "license": "MIT",
  "tier": "oss",
  "pricing": {
    "model": "free",
    "pricePC": 0,
    "priceUSD": 0
  },
  "category": "productivity",
  "icon": "🛒",
  "entry": "modules/pdv/index.jsx",
  "permissions": ["data:read", "data:write"],
  "dependencies": [],
  "minSDK": "1.0.0",
  "badges": ["panda-founder"],
  "mcp": {
    "tools": [
      {
        "name": "pdv_addItem",
        "description": "Adiciona item ao cardápio",
        "parameters": {
          "name": "string (required)",
          "price": "number (required)",
          "category": "string",
          "description": "string"
        }
      },
      {
        "name": "pdv_addToCart",
        "description": "Adiciona item ao carrinho de venda",
        "parameters": {
          "itemId": "string (required)",
          "qty": "number (default: 1)"
        }
      },
      {
        "name": "pdv_checkout",
        "description": "Finaliza venda do carrinho atual",
        "parameters": {
          "paymentMethod": "string (dinheiro|pix|cartao)"
        }
      },
      {
        "name": "pdv_listMenu",
        "description": "Lista todos os itens do cardápio",
        "parameters": {
          "category": "string (optional)"
        }
      }
    ]
  }
}
