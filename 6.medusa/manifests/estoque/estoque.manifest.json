{
  "panda_manifest_version": "1.0.0",
  "id": "estoque",
  "name": "Panda Estoque",
  "version": "1.0.0",
  "description": "Inventory management with stock tracking, alerts and adjustments",
  "author": "Panda Factory",
  "license": "MIT",
  "tier": "oss",
  "pricing": {
    "model": "free",
    "pricePC": 0,
    "priceUSD": 0
  },
  "category": "productivity",
  "icon": "📦",
  "entry": "modules/estoque/index.jsx",
  "permissions": ["data:read", "data:write"],
  "dependencies": [],
  "minSDK": "1.0.0",
  "badges": ["panda-founder"],
  "mcp": {
    "tools": [
      {
        "name": "estoque_addItem",
        "description": "Cadastra novo item no estoque",
        "parameters": {
          "name": "string (required)",
          "sku": "string",
          "unit": "string (un|kg|g|L|mL|cx|pct|m|m²)",
          "minStock": "number",
          "currentStock": "number"
        }
      },
      {
        "name": "estoque_adjustStock",
        "description": "Ajusta quantidade em estoque (entrada ou saída)",
        "parameters": {
          "itemId": "string (required)",
          "adjustment": "number (required, positive=entrada, negative=saída)",
          "reason": "string",
          "type": "string (entrada|saida|ajuste)"
        }
      },
      {
        "name": "estoque_listItems",
        "description": "Lista todos os itens do estoque com quantidades",
        "parameters": {
          "lowStockOnly": "boolean (default: false)"
        }
      },
      {
        "name": "estoque_getItem",
        "description": "Busca detalhes de um item específico",
        "parameters": {
          "itemId": "string (required)"
        }
      }
    ]
  }
}
