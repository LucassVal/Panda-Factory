{
  "panda_manifest_version": "1.0.0",
  "id": "facebook",
  "name": "Facebook Messenger",
  "version": "1.0.0",
  "description": "Facebook Messenger integration — DMs, auto-reply, page management",
  "author": "Panda Factory",
  "license": "MIT",
  "tier": "oss",
  "pricing": { "model": "free", "pricePC": 0, "priceUSD": 0 },
  "category": "social",
  "icon": "📘",
  "entry": "modules/facebook/index.jsx",
  "permissions": ["data:read", "data:write", "ui:panel"],
  "dependencies": [],
  "minSDK": "1.0.0",
  "badges": ["panda-founder"],
  "mcp": {
    "tools": [
      {
        "name": "fb_sendMessage",
        "description": "Envia mensagem via Facebook Messenger",
        "parameters": {
          "conversationId": "string (required)",
          "message": "string (required)"
        }
      },
      {
        "name": "fb_getConversations",
        "description": "Lista conversas do Messenger",
        "parameters": {}
      },
      {
        "name": "fb_toggleAutoReply",
        "description": "Ativa/desativa resposta automática IA",
        "parameters": { "enabled": "boolean (required)" }
      }
    ]
  }
}
